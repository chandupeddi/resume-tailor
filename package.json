  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "docx": "^9.7.1",
    "mammoth": "^1.8.0",
    "node-html-parser": "^6.1.13",
    "ora": "^8.0.1",
    "pdf-parse": "^1.1.1"
  },
  "type": "module",
